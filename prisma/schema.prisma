generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  telegramId   BigInt         @unique
  firstName    String
  lastName     String?
  username     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  energyLogs   EnergyLog[]
  messages     Message[]
  sessions     Session[]
  observations Observation[]
}

model EnergyLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  physical  Int
  mental    Int
  emotional Int
  spiritual Int
  note      String?
  logType   String   // "morning" | "evening" | "manual" | "auto"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String   // "user" | "assistant"
  content   String
  type      String   @default("text") // "text" | "voice"
  sessionId Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])
}

model Session {
  id        Int       @id @default(autoincrement())
  userId    Int
  status    String    @default("active") // "active" | "completed"
  summary   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

// Error and performance tracking for kaizen agent
model ErrorLog {
  id        Int      @id @default(autoincrement())
  source    String   // "bot" | "api" | "voice" | "ai" | "scheduler"
  message   String
  stack     String?
  context   String?  // JSON with extra info
  count     Int      @default(1)
  createdAt DateTime @default(now())
}

model Metric {
  id        Int      @id @default(autoincrement())
  name      String   // "ai_response_time" | "voice_transcribe_time" | "api_latency"
  value     Float
  tags      String?  // JSON tags
  createdAt DateTime @default(now())
}

// Structured data extracted from conversations by AI
model Observation {
  id           Int      @id @default(autoincrement())
  userId       Int
  energyType   String   // "physical" | "mental" | "emotional" | "spiritual"
  level        Int?     // 1-10 if mentioned
  direction    String   // "drop" | "rise" | "stable" | "low" | "high"
  trigger      String?  // what caused it: "долгое совещание", "плохой сон"
  recommendation String? // what was suggested
  context      String?  // free text context from conversation
  sessionId    Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

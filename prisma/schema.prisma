generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  telegramId     BigInt          @unique
  firstName      String
  lastName       String?
  username       String?
  timezone       String          @default("Asia/Shanghai")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  energyLogs     EnergyLog[]
  messages       Message[]
  sessions       Session[]
  observations   Observation[]
  habits         Habit[]
  habitLogs      HabitLog[]
  balanceRatings BalanceRating[]
  mission        Mission?
  balanceGoals   BalanceGoal[]
  goals          Goal[]
  algorithms     Algorithm[]
  reflections    Reflection[]
}

model EnergyLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  physical  Int
  mental    Int
  emotional Int
  spiritual Int
  note      String?
  logType   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  type      String   @default("text")
  sessionId Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])
}

model Session {
  id          Int          @id @default(autoincrement())
  userId      Int
  status      String       @default("active")
  summary     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  messages    Message[]
  reflections Reflection[]
}

model ErrorLog {
  id        Int      @id @default(autoincrement())
  source    String
  message   String
  stack     String?
  context   String?
  count     Int      @default(1)
  createdAt DateTime @default(now())
}

model Metric {
  id        Int      @id @default(autoincrement())
  name      String
  value     Float
  tags      String?
  createdAt DateTime @default(now())
}

model Observation {
  id             Int      @id @default(autoincrement())
  userId         Int
  energyType     String
  level          Int?
  direction      String
  trigger        String?
  recommendation String?
  context        String?
  sessionId      Int?
  energyLogId    Int?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model Habit {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  name                String
  icon                String
  type                String // "build" | "break"
  routineSlot         String // "morning" | "afternoon" | "evening"
  sortOrder           Int        @default(0)
  lifeArea            String? // "health" | "career" | "relationships" | "finances" | "family" | "growth" | "recreation" | "environment"
  energyType          String?
  frequency           String     @default("daily")
  customDays          String?
  triggerAction       String?
  duration            Int? // target duration in minutes (for duration-based habits)
  isDuration          Boolean    @default(false) // true = duration habit (start→finish)
  whyToday            String?
  whyMonth            String?
  whyYear             String?
  whyIdentity         String?
  isItBeneficial      String?
  breakTrigger        String?
  replacement         String?
  stage               String     @default("seed")
  stageUpdatedAt      DateTime   @default(now())
  streakCurrent       Int        @default(0)
  streakBest          Int        @default(0)
  consistency30d      Float      @default(0)
  freezesUsedThisWeek Int        @default(0)
  strength            Float      @default(0) // "habit strength" 0-100, grows slowly, decays gently
  gracePeriod         Int        @default(2) // max skips per week without losing streak
  gracesUsed          Int        @default(0) // skips used this week
  minimalDose         String? // e.g. "5 мин растяжки" — reduced version for low energy
  pausedAt            DateTime?
  pausedUntil         DateTime?
  microActionId       String?
  isActive            Boolean    @default(true)
  logs                HabitLog[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model HabitLog {
  id          Int       @id @default(autoincrement())
  habitId     Int
  habit       Habit     @relation(fields: [habitId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  date        DateTime  @db.Date
  startedAt   DateTime? // when duration habit was started
  completedAt DateTime  @default(now())
  status      String    @default("completed") // "started" | "completed"
  note        String?

  @@unique([habitId, date])
}

model BalanceRating {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  area           String // "health" | "career" | "relationships" | "finances" | "family" | "growth" | "recreation" | "environment"
  score          Int // 1-10
  note           String?
  createdAt      DateTime @default(now())
  subScores      Json?
  assessmentType String   @default("subjective")

  @@index([userId, area, createdAt])
}

model Mission {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  identity  String?
  purpose   String?
  legacy    String?
  statement String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Goal {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  lifeArea    String
  title       String
  description String?
  timeHorizon String
  period      String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, lifeArea, status])
}

model BalanceGoal {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  area        String
  targetScore Int
  identity    String?
  isFocus     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([userId, area])
}

model Algorithm {
  id                 Int         @id @default(autoincrement())
  userId             Int
  user               User        @relation(fields: [userId], references: [id])
  title              String
  icon               String
  lifeArea           String?
  steps              Json
  context            String?
  sourceReflectionId Int?
  sourceReflection   Reflection? @relation("AlgorithmReflection", fields: [sourceReflectionId], references: [id])
  usageCount         Int         @default(0)
  lastUsedAt         DateTime?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model Reflection {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  date          DateTime
  summary       String
  insights      Json?
  energyContext String?
  habitsContext String?
  algorithms    Algorithm[] @relation("AlgorithmReflection")
  sessionId     Int?
  session       Session?    @relation(fields: [sessionId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([userId, date])
}

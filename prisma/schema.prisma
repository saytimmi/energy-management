generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  telegramId   BigInt         @unique
  firstName    String
  lastName     String?
  username     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  energyLogs   EnergyLog[]
  messages     Message[]
  sessions     Session[]
  observations Observation[]
}

model EnergyLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  physical  Int
  mental    Int
  emotional Int
  spiritual Int
  note      String?
  logType   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  type      String   @default("text")
  sessionId Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])
}

model Session {
  id        Int       @id @default(autoincrement())
  userId    Int
  status    String    @default("active")
  summary   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

model ErrorLog {
  id        Int      @id @default(autoincrement())
  source    String
  message   String
  stack     String?
  context   String?
  count     Int      @default(1)
  createdAt DateTime @default(now())
}

model Metric {
  id        Int      @id @default(autoincrement())
  name      String
  value     Float
  tags      String?
  createdAt DateTime @default(now())
}

model Observation {
  id             Int      @id @default(autoincrement())
  userId         Int
  energyType     String
  level          Int?
  direction      String
  trigger        String?
  recommendation String?
  context        String?
  sessionId      Int?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}
